# SAM IMS — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Database (Render PostgreSQL connection string) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/sam_ims

# ── Cache (Render Redis) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-256-bit-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Chatbot ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
FRONTEND_URL=https://sam-ims-frontend.onrender.com

# ── Email (optional, for password reset) ────────────────────────────────────
# SENDGRID_API_KEY=SG.your-key-here
# FROM_EMAIL=noreply@yourdomain.com

# ── Error tracking (optional) ───────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
